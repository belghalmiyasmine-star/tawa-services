# Base de donnees
DATABASE_URL="postgresql://user:password@localhost:5432/tawa_services"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-minimum-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optionnel — laisser vide pour desactiver le login Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth (optionnel — laisser vide pour desactiver le login Facebook)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Resend (pour l'envoi d'emails de verification et reinitialisation de mot de passe)
RESEND_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
